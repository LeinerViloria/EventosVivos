# Plantilla del .env de PRODUCCIÓN (vive solo en el servidor; NO se versiona).
# Copia este archivo como ".env" junto al docker-compose.prod.yml y completa los valores.

# --- Despliegue ---
# Dueño de los paquetes en GHCR (en minúscula). Imagen: ghcr.io/${GHCR_OWNER}/eventosvivos-*
GHCR_OWNER=tu-usuario-github
# Tag de imagen a desplegar (latest, o una versión como 1.2.0).
IMAGE_TAG=latest
# Dominio y email para el certificado TLS automático (Caddy / Let's Encrypt).
DOMAIN=eventos-vivos.duckdns.org
ACME_EMAIL=tu-correo@example.com
# Token de DuckDNS: Caddy lo usa para el challenge DNS-01 (emitir el cert sin puertos 80/443).
DUCKDNS_TOKEN=tu-token-duckdns

# --- ASP.NET Core ---
ASPNETCORE_URLS=http://+:8080

# --- PostgreSQL ---
# POSTGRES_HOST lo fija el compose a "postgres" (red interna); aquí solo credenciales/DB.
POSTGRES_DB=eventosvivos
POSTGRES_USER=eventosvivos
POSTGRES_PASSWORD=replace-me

# --- Redis ---
# REDIS_HOST/PORT los fija el compose a redis:6379.
REDIS_PASSWORD=replace-me

# --- RabbitMQ ---
# RABBITMQ_HOST lo fija el compose a "rabbitmq".
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=eventosvivos
RABBITMQ_DEFAULT_PASS=replace-me

# --- JWT ---
JWT_ISSUER=eventosvivos
JWT_AUDIENCE=eventosvivos
JWT_SIGNING_KEY=replace-me-with-a-long-random-secret
JWT_IDENTITY_TOKEN_MINUTES=15
JWT_PERMISSIONS_TOKEN_MINUTES=15

# --- Reservations ---
RESERVATION_TTL_MINUTES=15
