# Plantilla de variables de entorno del backend.
# Copia este archivo como ".env" y reemplaza los valores. El ".env" real NO se versiona.

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# PostgreSQL
# Los hosts apuntan a localhost para la ejecución local (launch en el host).
# docker-compose los sobreescribe con los nombres de servicio cuando todo corre en contenedores.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=eventosvivos
POSTGRES_USER=eventosvivos
POSTGRES_PASSWORD=replace-me

# Redis
# El puerto 6380 es el que docker-compose expone en el host (6380:6379); docker-compose
# sobreescribe host y puerto a redis:6379 cuando la API corre dentro de la red de contenedores.
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=replace-me

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=eventosvivos
RABBITMQ_DEFAULT_PASS=replace-me

# JWT
JWT_ISSUER=eventosvivos
JWT_AUDIENCE=eventosvivos
JWT_SIGNING_KEY=replace-me-with-a-long-random-secret
JWT_IDENTITY_TOKEN_MINUTES=15
JWT_PERMISSIONS_TOKEN_MINUTES=15
